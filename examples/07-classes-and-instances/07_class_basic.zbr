// file: 07_class_basic.zbr
// teaches: class definition
// chapter: 07-Classes-and-Instances

class Person
    var name as str
    var age as int
    
    def greet
        print "Hi, I'm ${name}"

class Main
    shared
        def main
            var person = Person()
            person.name = "Alice"
            person.age = 30
            person.greet()  // Hi, I'm Alice