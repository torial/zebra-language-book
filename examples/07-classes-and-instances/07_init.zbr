// file: 07_init.zbr
// teaches: field initialization
// chapter: 07-Classes-and-Instances

class Rectangle
    var width as int = 0
    var height as int = 0
    
    def area as int
        return width * height

class Main
    shared
        def main
            var rect = Rectangle()
            rect.width = 10
            rect.height = 5
            print rect.area()  // 50