// file: 05_match_type.zbr
// teaches: type-based matching
// chapter: 05-Control-Flow

interface Animal
    def speak as str

class Dog
    implements Animal
        def speak as str
            return "Woof!"

class Cat
    implements Animal
        def speak as str
            return "Meow!"

class Main
    shared
        def main
            var pet as Animal = Dog()

            if pet implements Dog
                var d = pet to Dog
                print d.speak()
